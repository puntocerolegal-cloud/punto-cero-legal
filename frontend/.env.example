# Punto Cero Legal — Frontend Environment Variables
# Copy this file to frontend/.env.local for local development
# Vercel will automatically use environment variables configured in the dashboard

# Backend API URL (optional; auto-detected by default)
# If Vercel is serving from a production domain, it automatically uses the Render backend.
# For local development with a local backend, set this to:
# REACT_APP_BACKEND_URL=http://localhost:8000
REACT_APP_BACKEND_URL=https://puntocero-legal-api.onrender.com

# Storage encryption passphrase (optional)
# If set, user/token data in localStorage will be encrypted with AES-GCM
# Leave empty for plain text storage (still base64 encoded by default)
# REACT_APP_STORAGE_KEY=

# Next auth or other integrations can be added here as needed
