# ──────────────────────────────────────────────────────────────
# Punto Cero Legal — Variables de entorno (PLANTILLA)
# Copia este archivo a backend/.env y rellena con tus valores reales.
# NUNCA subas backend/.env al repositorio (está en .gitignore).
# En producción, carga estos valores en el panel de Render.
# ──────────────────────────────────────────────────────────────

# ── Base de datos (MongoDB Atlas en producción) ──
# Local:      mongodb://localhost:27017
# Producción: mongodb+srv://<usuario>:<password>@<cluster>.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017
DB_NAME=puntocero_legal

# ── Seguridad / app ──
SECRET_KEY=cambia-esto-por-una-cadena-larga-y-aleatoria
# Coma-separado. En producción: la URL exacta del frontend en Vercel.
CORS_ORIGINS=*
# URL pública del backend (la entrega Render tras el primer despliegue)
APP_PUBLIC_URL=https://puntocero-legal-api.onrender.com

# ── IA ──
GEMINI_API_KEY=tu-api-key-de-google-gemini
GEMINI_MODEL=gemini-flash-latest
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Meta WhatsApp Cloud API ──
META_APP_ID=tu-app-id
META_APP_SECRET=tu-app-secret
META_PHONE_NUMBER_ID=tu-phone-number-id
META_ACCESS_TOKEN=tu-access-token-permanente
META_WHATSAPP_NUMBER=+57XXXXXXXXXX
# Token que tú inventas y repites en el panel de Meta al configurar el webhook
META_VERIFY_TOKEN=puntocerolegal
META_GRAPH_VERSION=v21.0

# ── Correo (SMTP — Gmail con contraseña de aplicación de 16 caracteres) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=contrasena-de-aplicacion-16-chars
SMTP_FROM=tucorreo@gmail.com

# ── Pagos: MercadoPago (opcional; sin token usa links simulados) ──
MP_ACCESS_TOKEN=

# ── WhatsApp vía Twilio (alternativa a Meta — opcional) ──
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Documentos / Backups: Google Drive (opcional; sin esto usa MongoDB) ──
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=
