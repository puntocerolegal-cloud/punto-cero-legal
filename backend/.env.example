# Punto Cero Legal — variables de entorno del backend
# Copia este archivo a .env y rellena los valores reales. NUNCA commitees .env.

# --- Base de datos ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=punto_cero_legal

# --- CORS / App ---
CORS_ORIGINS=*
APP_PUBLIC_URL=https://app.puntocerolegal.com

# --- Seguridad ---
SECRET_KEY=cambia-esto-por-un-secreto-largo-aleatorio

# --- IA: Google Gemini Flash (gratis en https://aistudio.google.com/app/apikey) ---
GEMINI_API_KEY=

# --- Pagos: MercadoPago (opcional; sin token usa links simulados) ---
MP_ACCESS_TOKEN=

# --- Documentos: Google Drive Zero-Knowledge (opcional; sin esto usa MongoDB) ---
# Pega el JSON de la cuenta de servicio en una sola línea
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=
